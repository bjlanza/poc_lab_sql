#!/bin/bash

# SQL Lab - Inicialización
# Un solo script que lo hace todo

set -e

GREEN='\033[0;32m'
RED='\033[0;31m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "\n${BLUE}=== SQL Lab Init ===${NC}\n"

# 1. Node.js
if ! command -v node &>/dev/null; then
  echo "1. Instalando Node.js..."
  apt-get update -y
  apt-get install -y nodejs npm
else
  echo "1. Node.js: $(node -v)"
fi

# 2. SQLite
if ! command -v sqlite3 &>/dev/null; then
  echo "2. Instalando SQLite..."
  apt-get install -y sqlite3
else
  echo "2. SQLite: $(sqlite3 --version | awk '{print $1}')"
fi

# 3. npm install
echo "3. Instalando dependencias..."
cd web
npm install --prefer-offline --no-audit
cd ..

# 4. Directorios
echo "4. Creando directorios..."
mkdir -p /workspace/data

# 5. BDs
echo "5. Inicializando BDs..."
for lab in 01-basics 02-joins 03-aggregates; do
  sqlite3 /workspace/data/$lab.db < labs/$lab/init.sql
  echo "   ✓ $lab.db"
done

# 6. Progress
echo "6. Creando progress file..."
echo '{"started": "'$(date -u +%Y-%m-%dT%H:%M:%SZ)'", "labs": {}}' > /workspace/.progress.json

# 7. Lanzar servidor en background
echo "7. Iniciando servidor..."
cd web
npm start > /workspace/.server.log 2>&1 &
SERVER_PID=$!
echo $SERVER_PID > /workspace/.server.pid
cd ..

# Esperar a que el servidor esté listo (curl al endpoint)
max_attempts=30
attempt=0
while ! curl -s http://localhost:3000 > /dev/null 2>&1 && [ $attempt -lt $max_attempts ]; do
  sleep 1
  attempt=$((attempt + 1))
done

if curl -s http://localhost:3000 > /dev/null 2>&1; then
  echo -e "\n${GREEN}✓ Servidor listo${NC}\n"
  echo -e "${BLUE}SQL Lab está corriendo!${NC}"
  echo ""
  echo "Abre en tu navegador:"
  echo "  ${YELLOW}http://localhost:3000${NC}"
  echo ""
  echo "La terminal está libre para usar. El servidor corre en background."
  echo ""
else
  echo -e "\n${YELLOW}⚠ Servidor aún iniciando...${NC}"
  echo "Revisa: tail -f /workspace/.server.log"
  echo ""
fi
